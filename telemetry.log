6pv5","eventName":"DocumentChangeEvent","eventTime":1773777700846,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"replace","value":"export const createUser = async (user: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(user.password, 10);\n\n  const result = await db.run(\n    `\n    INSERT INTO users (email, password, firstName, lastName, displayName)\n    VALUES (?, ?, ?, ?, ?)\n    `,\n    user.email,\n    hashedPassword,\n    user.firstName || null,\n    user.lastName || null,\n    user.displayName || null\n  );\n\n  await db.close();\n\n  return {\n    ...user,\n    id: result.lastID,\n    password: hashedPassword, \n  };\n};","rangeOffset":"232","rangeLength":"34","rangestart_line":"7","rangestart_character":"0","rangeend_line":"7","rangeend_character":"34"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"WindowStateChangeEvent","eventTime":1773777709135,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"WindowStateChangeEvent","eventTime":1773777750772,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","