0-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"DocumentChangeEvent","eventTime":1773778160572,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":14,"operation":"replace","value":"export const registerUser = async (req: Request, res: Response): Promise<void> => {\n  try {\n    const { email, password, firstName, lastName } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required' });\n      return;\n    }\n\n    const newUser: PlatformUser = {\n      id: null,\n      email,\n      password,\n      firstName,\n      lastName,\n    };\n\n    const createdUser = await createUser(newUser);\n\n    res.status(201).json({\n      message: 'User created successfully',\n      user: createdUser,\n    });\n\n  } catch (error: any) {\n    console.error('registerUser error:', error);\n\n    if (error?.message?.includes('UNIQUE constraint failed')) {\n      res.status(409).json({ message: 'User already exists' });\n      return;\n    }\n\n    res.status(500).json({ message: 'Internal server error' });\n  }\n};","rangeOffset":"194","rangeLength":"238","rangestart_line":"5","rangestart_character":"0","rangeend_line":"15","rangeend_character":"2"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"DocumentSaveEvent","eventTime":1773778163717,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","doc