eplace","value":"import { Request, Response } from 'express';\nimport { createUser } from \"../models/User\";\n\nexport const registerUser = async (req: Request, res: Response): Promise<void> => {\n  try {\n    const { email, password, firstName, lastName } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required' });\n      return;\n    }\n\n    const createdUser = await createUser({\n      email,\n      password,\n      firstName,\n      lastName,\n    });\n\n    res.status(201).json({\n      message: 'User created successfully',\n      user: createdUser,\n    });\n\n  } catch (error: any) {\n    console.error('registerUser error:', error);\n\n    if (error?.message?.includes('UNIQUE constraint failed')) {\n      res.status(409).json({ message: 'User already exists' });\n      return;\n    }\n\n    res.status(500).json({ message: 'Internal server error' });\n  }\n};","rangeOffset":"194","rangeLength":"849","rangestart_line":"5","rangestart_character":"0","rangeend_line":"38","rangeend_character":"2"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"DocumentChangeEvent","eventTime":1773779571396,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":14,"operation":"delete","value":"","rangeOffset":"194","rangeLength":"89","rangestart_line":"5","rangestart_character":"0","rangeend_line":"6","rangeend_character":"44"},{"codespaceName":"super-garbanzo-v9xp5pqv94xf6pv5","eventName":"DocumentChangeEvent","eventTime":1773779571834,"sessionId":"4e190500-f435-4483-80a8-2f5f4b9f2a6d1773776662721","machineId":"cbfec1515b05bcfe358c136cc684b05c52ae40bc6366def82a9464debf88f748","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":14,"operation":"d